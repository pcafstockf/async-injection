{
		"extends": "./tsconfig.cjs.json",
		"compilerOptions": {
				"noEmit": true,
				"rootDir": ".",
				"paths": {
						"async-injection": [
								"./src/index.ts"
						],
						"async-injection/*": [
								"./src/*"
						]
				}
		},
		"include": [
				"./src/**/*",
				"./spec/**/*"
		],
		"exclude": [
				"node_modules"
		]
}
